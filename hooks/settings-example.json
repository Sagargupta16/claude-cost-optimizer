{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "_comment": [
    "Example Claude Code settings with budget enforcement hooks.",
    "Copy this file to ~/.claude/settings.json (global) or .claude/settings.json (project).",
    "Update the paths below to point to wherever you cloned claude-cost-optimizer.",
    "Environment variables (optional):",
    "  BUDGET_TOOL_LIMIT  - max tool calls before warning (default: 50)",
    "  BUDGET_WARN_AT     - warn at this percentage of the limit (default: 80)",
    "  BUDGET_LOG_DIR     - directory for counter/log files (default: /tmp/claude-budget)"
  ],

  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          "bash /path/to/claude-cost-optimizer/hooks/budget-tracker.sh"
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          "bash /path/to/claude-cost-optimizer/hooks/session-summary.sh"
        ]
      }
    ]
  }
}
