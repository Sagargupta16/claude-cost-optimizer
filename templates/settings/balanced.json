{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "_comment": [
    "BALANCED SETTINGS - Recommended default profile.",
    "Sonnet for most tasks. Reasonable limits, good quality-to-cost ratio.",
    "Best for: most teams, daily development, standard feature work.",
    "Copy this file to ~/.claude/settings.json or .claude/settings.json"
  ],

  "model": "sonnet",

  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(npm test*)",
      "Bash(npm run *)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(curl*)",
      "Bash(wget*)"
    ]
  },

  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session paused - review token usage with /usage'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
